generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  profile        UserProfile?
  jobs           Job[]
  resumes        Resume[]
  searchConfigs  SearchConfig[]
  pipelineRuns   PipelineRun[]
  outreachEmails OutreachEmail[]
}

model Job {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  company         String
  location        String?
  locationType    String?
  url             String
  source          String
  description     String?
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String?      @default("USD")
  experienceLevel String?
  companySize     String?
  industry        String?
  tags            String       @default("[]")
  postedAt        DateTime?
  scrapedAt       DateTime     @default(now())
  matchScore      Int          @default(0)
  status          String       @default("new")
  companyInfoId   String?
  companyInfo     CompanyInfo? @relation(fields: [companyInfoId], references: [id])
  analyses        ResumeAnalysis[]
  application     Application?
  coverLetters    CoverLetter[]
  tailoredResumes TailoredResume[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([title, company, source, userId])
  @@index([userId])
  @@index([status])
  @@index([matchScore])
  @@index([createdAt])
}

model Resume {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  fileName        String
  textContent     String
  format          String
  isPrimary       Boolean          @default(false)
  wordCount       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  analyses        ResumeAnalysis[]
  coverLetters    CoverLetter[]
  tailoredResumes TailoredResume[]

  @@index([userId])
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  resumeId        String
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  matchScore      Int
  presentKeywords String   @default("[]")
  missingKeywords String   @default("[]")
  suggestions     String   @default("[]")
  summary         String   @default("")
  createdAt       DateTime @default(now())

  @@unique([resumeId, jobId])
}

model SearchConfig {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String   @default("Default")
  titles               String   @default("[]")
  locations            String   @default("[]")
  locationType         String?
  experienceLevel      String?
  salaryMin            Int?
  salaryMax            Int?
  companySize          String?
  industries           String   @default("[]")
  includeKeywords      String   @default("[]")
  excludeKeywords      String   @default("[]")
  blacklistedCompanies String   @default("[]")
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model Application {
  id                String    @id @default(cuid())
  jobId             String    @unique
  job               Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status            String    @default("bookmarked")
  notes             String    @default("")
  recruiterName     String    @default("")
  recruiterEmail    String    @default("")
  recruiterLinkedIn String    @default("")
  followUpDate      DateTime?
  appliedAt         DateTime?
  timeline          String    @default("[]")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
}

model CoverLetter {
  id        String   @id @default(cuid())
  resumeId  String
  resume    Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  content   String
  tone      String   @default("professional")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resumeId, jobId])
}

model PipelineRun {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           String
  scrapeCount      Int       @default(0)
  newJobsCount     Int       @default(0)
  analyzedCount    Int       @default(0)
  coverLetterCount Int       @default(0)
  autoTrackedCount Int       @default(0)
  errors           String    @default("[]")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([userId])
}

model OutreachEmail {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyUrl   String
  companyName  String
  companyInfo  String
  emailSubject String
  emailBody    String
  resumeId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model TailoredResume {
  id             String   @id @default(cuid())
  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  latexSource    String
  resumeJson     String
  projectedScore Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([resumeId, jobId])
  @@index([resumeId])
  @@index([jobId])
}

model UserProfile {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("")
  email     String   @default("")
  phone     String   @default("")
  linkedin  String   @default("")
  github    String   @default("")
  location  String   @default("")
  updatedAt DateTime @updatedAt
}

model CompanyInfo {
  id           String   @id @default(cuid())
  name         String   @unique
  size         String?
  industry     String?
  description  String?
  fundingStage String?
  website      String?
  jobs         Job[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
